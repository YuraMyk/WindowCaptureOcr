<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Target Windows 10 1809+ for Windows.Media.Ocr WinRT API -->
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationIcon />
    <AssemblyTitle>Window Capture OCR</AssemblyTitle>
    <Product>Window Capture OCR</Product>
    <!-- Required to use WinRT APIs like Windows.Media.Ocr -->
    <RuntimeIdentifiers>win-x64;win-x86</RuntimeIdentifiers>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- Copy clans.json next to the executable so ClanLookupService finds it -->
    <Content Include="clans.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="10.0.7" />
  </ItemGroup>

</Project>
