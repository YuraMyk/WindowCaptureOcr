<Window x:Class="WindowCaptureOcr.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="480" Height="230"
        MinWidth="360" MinHeight="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Background" Value="#3389B4FA"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Background="#F0181825"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>   <!-- title bar -->
                <RowDefinition Height="*"/>    <!-- content -->
                <RowDefinition Height="44"/>   <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Border Grid.Row="0" Background="#22FFFFFF" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <DockPanel Margin="12,0,6,0" LastChildFill="False">
                    <TextBlock Text="⚙  Settings" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="12" Foreground="#CDD6F4"/>
                    <Button Style="{StaticResource IconBtn}" Content="✕"
                            DockPanel.Dock="Right" Foreground="#6C7086"
                            Click="Cancel_Click"/>
                </DockPanel>
            </Border>

            <!-- ── Content ── -->
            <StackPanel Grid.Row="1" Margin="16,12,16,0" VerticalAlignment="Top">

                <!-- Clans JSON URL -->
                <TextBlock Text="Clans JSON download URL" FontSize="11"
                           Foreground="#6C7086" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UrlBox"
                             Grid.Column="0"
                             Background="#1EFFFFFF" Foreground="#CDD6F4"
                             BorderBrush="#44FFFFFF" BorderThickness="1"
                             CaretBrush="#CDD6F4"
                             Padding="8,5" FontSize="11"
                             ToolTip="Google Drive share link or any direct HTTPS URL returning JSON"/>
                    <Button Grid.Column="1" Style="{StaticResource IconBtn}"
                            Content="Test" FontSize="11" Foreground="#89DCEB"
                            Margin="6,0,0,0" ToolTip="Resolve and display the download URL"
                            Click="TestUrl_Click"/>
                </Grid>
                <TextBlock x:Name="ResolvedUrlText"
                           FontSize="10" Foreground="#456C7086"
                           Margin="0,3,0,0" TextWrapping="Wrap"
                           Text="Paste a Google Drive share link or direct URL above."/>

                <!-- Fuzzy threshold -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fuzzy match threshold (0.0 – 1.0)"
                               FontSize="11" Foreground="#6C7086" VerticalAlignment="Center"/>
                    <TextBox x:Name="ThresholdBox" Grid.Column="1"
                             Background="#1EFFFFFF" Foreground="#CDD6F4"
                             BorderBrush="#44FFFFFF" BorderThickness="1"
                             CaretBrush="#CDD6F4"
                             Padding="6,4" FontSize="11" TextAlignment="Center"
                             ToolTip="Minimum Levenshtein similarity to accept as a match (default 0.75)"/>
                </Grid>

            </StackPanel>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" Background="#14FFFFFF" CornerRadius="0,0,8,8">
                <DockPanel Margin="12,0,8,0" LastChildFill="False">
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                               FontSize="10" Foreground="#6C7086" Opacity=".7"/>
                    <Button Style="{StaticResource IconBtn}" Content="Cancel"
                            DockPanel.Dock="Right" Foreground="#6C7086"
                            Click="Cancel_Click"/>
                    <Button Style="{StaticResource AccentBtn}" Content="  Save  "
                            DockPanel.Dock="Right" Margin="0,0,4,0"
                            Click="Save_Click"/>
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
