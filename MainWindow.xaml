<Window x:Class="WindowCaptureOcr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Overlay"
        Width="400" Height="200"
        MinWidth="200" MinHeight="170"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True">

    <Window.Resources>

        <!-- Flat icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <!-- Outer shell: rounded corners + clip -->
    <Border x:Name="Shell" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <!-- top bar -->
                <RowDefinition Height="*"/>
                <!-- transparent capture zone -->
                <RowDefinition x:Name="OcrRow" Height="80"/>
                <!-- OCR text panel -->
            </Grid.RowDefinitions>

            <!-- ════ TOP BAR ════ -->
            <Border Grid.Row="0" Background="#E8181825" x:Name="TopBar">
                <DockPanel Margin="10,0,4,0" LastChildFill="False">

                    <!-- Status indicator dot -->
                    <Ellipse x:Name="StatusDot" Width="7" Height="7"
                             VerticalAlignment="Center" Margin="0,0,7,0"
                             Fill="#45475A"/>

                    <TextBlock Text="OCR Overlay" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="12"
                               Foreground="#CDD6F4" Margin="0,0,0,0"/>

                    <!-- Right-side controls (DockPanel.Dock="Right" stacks right→left) -->

                    <!-- Close -->
                    <Button Style="{StaticResource IconBtn}" Content="✕"
                            DockPanel.Dock="Right"
                            Foreground="#6C7086"
                            ToolTip="Close application"
                            Click="Close_Click"/>

                     <!-- Settings -->
                    <Button x:Name="BtnSettings" Style="{StaticResource IconBtn}"
                            Content="⚙" DockPanel.Dock="Right"
                            Foreground="#6C7086"
                            ToolTip="Open settings"
                            Click="Settings_Click"/>

                    <!-- Refresh clans.json -->
                    <Button x:Name="BtnRefresh" Style="{StaticResource IconBtn}"
                            Content="⟳" DockPanel.Dock="Right"
                            Foreground="#89DCEB"
                            FontSize="14"
                            ToolTip="Download &amp; reload clans.json"
                            Click="RefreshClans_Click"/>
							
                    <!-- Start / Stop -->
                    <Button x:Name="BtnStartStop" Style="{StaticResource IconBtn}"
                            Content="■  Stop" DockPanel.Dock="Right"
                            Foreground="#F38BA8"
                            Click="StartStop_Click"/>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="16" Fill="#33FFFFFF"
                               DockPanel.Dock="Right" Margin="4,0"/>

                    <!-- Interval -->
                    <TextBlock Text="ms" VerticalAlignment="Center"
                               DockPanel.Dock="Right" Foreground="#6C7086"
                               FontSize="11" Margin="0,0,6,0"/>
                    <TextBox x:Name="IntervalBox" Text="800" Width="44"
                             Style="{StaticResource DarkTextBox}"
                             DockPanel.Dock="Right" Margin="0,0,3,0"
                             ToolTip="Capture interval in milliseconds"/>
                    <TextBlock Text="Interval:" VerticalAlignment="Center"
                               DockPanel.Dock="Right" Foreground="#6C7086"
                               FontSize="11" Margin="0,0,5,0"/>

                </DockPanel>
            </Border>

            <!-- ════ CAPTURE ZONE (fully transparent) ════ -->
            <Grid Grid.Row="1" x:Name="CaptureZone" Background="Transparent">

                <!-- Dashed boundary marker — invisible to BitBlt because it's our window -->
                <Rectangle x:Name="ZoneBorder"
                           Stroke="#7089B4FA" StrokeThickness="1"
                           StrokeDashArray="9 4"
                           Fill="Transparent"
                           IsHitTestVisible="False"
                           SnapsToDevicePixels="True"/>

                <!-- Dimension hint, top-left corner -->
                <TextBlock x:Name="SizeHint"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           Margin="4,2" FontSize="9"
                           Foreground="#5089B4FA"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- ════ OCR OUTPUT PANEL ════ -->
            <Border Grid.Row="2" x:Name="OcrPanel" Background="#E8181825">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#18FFFFFF">
                        <DockPanel Margin="8,0,4,0" LastChildFill="False">
                            <TextBlock Text="Recognized Text" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#6C7086"/>
                            <TextBlock x:Name="FpsText" DockPanel.Dock="Right"
                                       VerticalAlignment="Center" FontSize="10"
                                       Foreground="#356C7086" Margin="0,0,6,0"/>
                            <Button Style="{StaticResource IconBtn}" Content="Clear"
                                    DockPanel.Dock="Right" FontSize="11"
                                    Foreground="#6C7086" Click="ClearText_Click"/>
                            <Button Style="{StaticResource IconBtn}" Content="Copy"
                                    DockPanel.Dock="Right" FontSize="11"
                                    Foreground="#89B4FA" Click="CopyText_Click"/>
                        </DockPanel>
                    </Border>

                    <!-- Text area -->
                    <TextBox Grid.Row="1" x:Name="OcrTextBox"
                             Background="Transparent"
                             Foreground="#A6E3A1"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12" Padding="8,5"
                             SelectionBrush="#4489B4FA"/>

                    <!-- ── Clan info strip (row 2) ───────────────────── -->
                    <Border Grid.Row="2" x:Name="ClanInfoPanel"
                            Background="#14FFFFFF"
                            BorderThickness="0,1,0,0" BorderBrush="#1AFFFFFF"
                            Padding="8,5,8,4">
                        <StackPanel Orientation="Vertical" Margin="0">

                            <!-- Line 1: badge → clan name → leader (all in one row) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="StatusBadge"
                                        CornerRadius="3" Padding="6,2"
                                        Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="StatusText"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#1E1E2E"
                                               Text="—"/>
                                </Border>
                                <TextBlock x:Name="ClanNameText"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#89B4FA"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           Text="—"/>
                                <TextBlock x:Name="LeaderText"
                                           FontSize="11" Foreground="#6C7086"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- ── Manual search strip (row 3) ───────────────────── -->
                    <Border Grid.Row="3" Background="#0CFFFFFF"
                            BorderThickness="0,1,0,0" BorderBrush="#12FFFFFF"
                            Padding="10,2,10,0">
                        <DockPanel LastChildFill="True">
                            <Button x:Name="BtnManualSearch"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource IconBtn}"
                                    Content="Search"
                                    Foreground="#89B4FA"
                                    Padding="10,3"
                                    FontSize="11"
                                    Click="ManualSearch_Click"/>
                            <!-- lock indicator shown while manual result is pinned -->
                            <TextBlock x:Name="LockCountdown"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       FontSize="10" Foreground="#6C7086"
                                       Margin="0,0,6,0"
                                       Visibility="Collapsed"/>
                            <TextBox x:Name="ManualSearchBox"
                                     Style="{StaticResource DarkTextBox}"
                                     FontSize="11"
                                     VerticalContentAlignment="Center"
                                     Padding="5,3"
                                     Height="24"
                                     Margin="0,0,6,0"
                                     ToolTip="Type a clan name and press Search"
                                     KeyDown="ManualSearchBox_KeyDown"/>
                        </DockPanel>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
